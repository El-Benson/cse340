<%- messages() %>
<div class="hero">
  <h1>Welcome to CSE Motors!</h1>
  <div class="hero-content">
    <img class="hero-car" src="/images/vehicles/delorean.jpg" 
         alt="Silver DMC Delorean sports car">
    <div class="heromsg">
      <h2>DMC Delorean</h2>
      <p>3 Cup Holders</p>
      <p>Superman Doors</p>
      <p>Fuzzy Dice</p>
      <a href="#" class="own-today-btn">Own Today</a>
    </div>
  </div>
</div>

<div class="delorean-info">

  <!-- Reviews FIRST (matches mobile screenshot order) -->
  <div class="d-reviews">
    <h2>DMC Delorean Reviews</h2>
    <ul>
      <li>"So fast it's almost like traveling in time." (4/5)</li>
      <li>"Coolest ride on the road." (4/5)</li>
      <li>"I'm feeling McFly!" (5/5)</li>
      <li>"The most futuristic ride of our day." (4.5/5)</li>
      <li>"80's livin and I love it!" (5/5)</li>
    </ul>
  </div>

  <!-- Upgrades SECOND (matches mobile screenshot order) -->
  <div class="d-upgrades">
    <h2>Delorean Upgrades</h2>
    <div class="upgrade-grid">
      <div class="upgrade-info">
        <img src="/images/upgrades/flux-cap.png" 
             alt="Flux capacitor upgrade accessory">
        <a href="#">Flux Capacitor</a>
      </div>
      <div class="upgrade-info">
        <img src="/images/upgrades/flame.jpg" 
             alt="Flame decal design for car exterior">
        <a href="#">Flame Decals</a>
      </div>
      <div class="upgrade-info">
        <img src="/images/upgrades/bumper_sticker.jpg" 
             alt="Custom bumper sticker accessory">
        <a href="#">Bumper Stickers</a>
      </div>
      <div class="upgrade-info">
        <img src="/images/upgrades/hub-cap.jpg" 
             alt="Shiny chrome hub caps for wheels">
        <a href="#">Hub Caps</a>
      </div>
    </div>
  </div>

</div>
